# Gitignore file for Water Data Visualization Project

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
*.tsbuildinfo

# Logs and debugging
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.local

# ETL specific
etl/logs/*
!etl/logs/.gitkeep
etl/data/*
!etl/data/.gitkeep

# Frontend public data
frontend/public/data/*
!frontend/public/data/.gitkeep

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp
