# ETL Configuration File

# === SOCRATA API ENDPOINTS ===
# Base URL for Catalan Government Open Data Portal
SOCRATA_BASE_URL=https://analisi.transparenciacatalunya.cat

# Dataset IDs (Socrata Dataset Identifiers - These are PERMANENT)
EMBASSAMENTS_DATASET_ID=gn9e-3qhr
PRECIPITATION_DATASET_ID=7bvh-jvq2

# Full API URLs (constructed from above)
EMBASSAMENTS_API_URL=https://analisi.transparenciacatalunya.cat/resource/gn9e-3qhr.json
PRECIPITATION_API_URL=https://analisi.transparenciacatalunya.cat/resource/7bvh-jvq2.json

# === DATA SETTINGS ===
DATA_RETENTION_DAYS=365
DATA_UPDATE_FREQUENCY=daily

# Maximum records to fetch per request (Socrata limit is 50k)
API_MAX_RECORDS=50000

# === LOGGING ===
LOG_LEVEL=info
LOG_FILE=./logs/etl.log

# === HEALTH CHECK ===
# Enable health checks before ETL runs
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_TIMEOUT_MS=5000

# === BACKEND (Optional) ===
BACKEND_PORT=5000
BACKEND_HOST=localhost

# === ENVIRONMENT ===
NODE_ENV=development
